# consumer-service API 接口验证
# 使用 VS Code REST Client 插件运行 (humao.rest-client)
#
# 直连 consumer-service:    @baseUrl = http://127.0.0.1:8001
# 经 API Gateway 访问:  @baseUrl = http://127.0.0.1:8080

@baseUrl = http://127.0.0.1:8001
@adminToken = {{adminLogin.response.body.access_token}}


###############################################################
# 健康检查
###############################################################

# @name health
GET {{baseUrl}}/health

###

# @name healthReady
GET {{baseUrl}}/health/ready


###############################################################
# 认证
###############################################################

# @name adminLogin
# 管理员登录
POST {{baseUrl}}/api/auth/admin/login
Content-Type: application/json

{
  "username": "admin",
  "password": "Admin@123"
}

###

# @name logout
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{adminToken}}


###############################################################
# 权限管理
###############################################################

# @name listPermissions
GET {{baseUrl}}/api/permissions
Authorization: Bearer {{adminToken}}

###

# @name getPermission
GET {{baseUrl}}/api/permissions/1
Authorization: Bearer {{adminToken}}

###

# @name createPermission
POST {{baseUrl}}/api/permissions
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "code": "report:view",
  "name": "查看报表",
  "type": "api",
  "method": "GET",
  "path": "/api/v1/reports"
}

###

# @name updatePermission
PUT {{baseUrl}}/api/permissions/1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "超级权限（所有接口）"
}

###

# @name deletePermission
DELETE {{baseUrl}}/api/permissions/999
Authorization: Bearer {{adminToken}}


###############################################################
# 角色管理
###############################################################

# @name listRoles
GET {{baseUrl}}/api/roles
Authorization: Bearer {{adminToken}}

###

# @name getRole
GET {{baseUrl}}/api/roles/1
Authorization: Bearer {{adminToken}}

###

# @name createRole
POST {{baseUrl}}/api/roles
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "operator",
  "desc": "运营人员，拥有商品和订单读取权限"
}

###

# @name updateRole
PUT {{baseUrl}}/api/roles/1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "desc": "超级管理员，拥有全部权限"
}

###

# @name assignPermissionsToRole
# 给角色分配权限（permission_ids 数组）
POST {{baseUrl}}/api/roles/1/permissions
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "permission_ids": [1, 2, 3]
}

###

# @name deleteRole
DELETE {{baseUrl}}/api/roles/999
Authorization: Bearer {{adminToken}}


###############################################################
# 用户管理
###############################################################

# @name listUsers
GET {{baseUrl}}/api/users
Authorization: Bearer {{adminToken}}

###

# @name getUser
GET {{baseUrl}}/api/users/1
Authorization: Bearer {{adminToken}}

###

# @name createUser
POST {{baseUrl}}/api/users
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "username": "operator01",
  "password": "Operator@123",
  "status": "active"
}

###

# @name updateUser
PUT {{baseUrl}}/api/users/1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "username": "admin"
}

###

# @name updateUserStatus
# 启用 / 禁用账号（status: "active" | "disabled"）
POST {{baseUrl}}/api/users/1/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "active"
}

###

# @name assignRolesToUser
# 给用户分配角色（role_ids 数组）
POST {{baseUrl}}/api/users/1/roles
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "role_ids": [1]
}

###

# @name deleteUser
DELETE {{baseUrl}}/api/users/999
Authorization: Bearer {{adminToken}}
