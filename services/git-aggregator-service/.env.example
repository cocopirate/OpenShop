SERVICE_NAME=git-aggregator-service
SERVICE_PORT=8000
DEBUG=true
ENV=development
DATABASE_URL=postgresql+asyncpg://openshop:openshop123@localhost:5432/openshop
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
# Webhook secrets
CODEUP_TOKEN=change-this-codeup-token
GITHUB_WEBHOOK_SECRET=change-this-github-secret
GITLAB_TOKEN=change-this-gitlab-token
# Optional: comma-separated IP whitelist (empty = disabled)
IP_WHITELIST=
# Anti-replay window in seconds
MAX_TIMESTAMP_DELAY=300
