SERVICE_NAME=admin-service
SERVICE_PORT=8012
DEBUG=true
ENV=development
DATABASE_URL=postgresql+asyncpg://openshop:openshop123@localhost:5432/openshop
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
REDIS_URL=redis://:redis123@localhost:6379/0
REDIS_POOL_MAX_SIZE=10
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin seed (idempotent)
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=Admin@123456
INIT_ADMIN_REAL_NAME=System Admin
INIT_ADMIN_ROLE_CODE=super_admin
INIT_ADMIN_ROLE_NAME=超级管理员
INIT_ADMIN_FORCE_RESET_PASSWORD=false
