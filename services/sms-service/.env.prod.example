# sms-service – Production environment
# Inject these values via K8s Secrets or CI/CD vault. Do NOT store real values here.

SERVICE_NAME=sms-service
SERVICE_PORT=8010
DEBUG=false
ENV=production

# PostgreSQL (cloud-managed, read from K8s Secret)
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/sms_prod
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30

# Redis (cloud-managed, read from K8s Secret)
REDIS_URL=redis://:<password>@<host>:6379/0
REDIS_POOL_MIN_SIZE=5
REDIS_POOL_MAX_SIZE=20

# RabbitMQ
RABBITMQ_URL=amqp://openshop:openshop123@rabbitmq:5672/

# Active provider: "aliyun" | "tencent" | "chuanglan"
SMS_PROVIDER=chuanglan
SMS_PROVIDER_FALLBACK=aliyun
SMS_CODE_TTL=300

# Rate limits
SMS_RATE_LIMIT_PHONE_PER_MINUTE=1
SMS_RATE_LIMIT_PHONE_PER_DAY=10
SMS_RATE_LIMIT_IP_PER_MINUTE=10
SMS_RATE_LIMIT_IP_PER_DAY=100

# ChuangLan (创蓝云) SMS (read from K8s Secret)
CHUANGLAN_ACCOUNT=<secret>
CHUANGLAN_PASSWORD=<secret>
CHUANGLAN_API_URL=https://smssh1.253.com/msg/v1/send/json

# Aliyun SMS (read from K8s Secret)
ALIYUN_ACCESS_KEY_ID=<secret>
ALIYUN_ACCESS_KEY_SECRET=<secret>
ALIYUN_SMS_SIGN_NAME=OpenShop
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# Tencent Cloud SMS (leave blank if not using)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
