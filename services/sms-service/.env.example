# sms-service – Local development environment
# Copy to .env and fill in real values.
# Priority (high → low): system env vars > .env > .env.local
# DO NOT commit .env to source control.

SERVICE_NAME=sms-service
SERVICE_PORT=8010
DEBUG=true
ENV=development

# PostgreSQL (local docker-compose)
DATABASE_URL=postgresql+asyncpg://openshop:openshop123@localhost:5432/openshop
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis (local docker-compose)
REDIS_URL=redis://:redis123@localhost:6379/0
REDIS_POOL_MIN_SIZE=2
REDIS_POOL_MAX_SIZE=10

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Active provider: "aliyun" | "tencent" | "chuanglan"
SMS_PROVIDER=chuanglan
# Fallback provider (used when primary circuit breaker opens)
SMS_PROVIDER_FALLBACK=
# Circuit breaker thresholds
SMS_PROVIDER_FAILURE_THRESHOLD=3
SMS_PROVIDER_RECOVERY_TIMEOUT=60

# Verification code TTL (seconds)
SMS_CODE_TTL=300

# Rate limits
SMS_RATE_LIMIT_PHONE_PER_MINUTE=1
SMS_RATE_LIMIT_PHONE_PER_DAY=10
SMS_RATE_LIMIT_IP_PER_MINUTE=10
SMS_RATE_LIMIT_IP_PER_DAY=100

# Records retention
SMS_RECORDS_RETENTION_DAYS=90

# ChuangLan (创蓝云) SMS – default provider
CHUANGLAN_ACCOUNT=your-account
CHUANGLAN_PASSWORD=your-password
CHUANGLAN_API_URL=https://smssh1.253.com/msg/v1/send/json

# Aliyun SMS (leave blank if using ChuangLan)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# Tencent Cloud SMS (leave blank if not using)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=

# OpenTelemetry (leave blank to disable tracing)
OTEL_ENDPOINT=
OTEL_TOKEN=
