# sms-service – Local development environment
# Copy to .env and fill in real values.
# Priority (high → low): system env vars > .env > .env.local
# DO NOT commit .env to source control.

SERVICE_NAME=sms-service
SERVICE_PORT=8010
DEBUG=true
ENV=development

# PostgreSQL (local docker-compose)
DATABASE_URL=postgresql+asyncpg://openshop:openshop123@localhost:5432/openshop
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis (local docker-compose)
REDIS_URL=redis://:redis123@localhost:6379/0
REDIS_POOL_MIN_SIZE=2
REDIS_POOL_MAX_SIZE=10

# RabbitMQ
RABBITMQ_URL=amqp://openshop:openshop123@localhost:5672/

# OpenTelemetry (leave blank to disable tracing)
OTEL_ENDPOINT=
OTEL_TOKEN=

# ---------------------------------------------------------------------------
# SMS provider configuration is NOT managed via environment variables.
# Use PUT /api/sms/config to configure providers, credentials, rate limits,
# and channel routing. Changes are persisted to the sms_config_store table
# and automatically restored on service restart.
#
# Example – configure ChuangLan as the active provider:
#   curl -X PUT http://localhost:8010/api/sms/config \
#     -H "Content-Type: application/json" \
#     -d '{"sms_provider":"chuanglan","chuanglan":{"account":"xxx","password":"xxx"}}'
# ---------------------------------------------------------------------------
