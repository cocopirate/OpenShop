# sms-service – Local development environment
# Copy to .env and fill in real values.
# DO NOT commit .env to source control.

SERVICE_NAME=sms-service
SERVICE_PORT=8010
DEBUG=true

# PostgreSQL (local docker-compose)
DATABASE_URL=postgresql+asyncpg://openshop:openshop123@localhost:5432/openshop
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis (local docker-compose)
REDIS_URL=redis://:redis123@localhost:6379/0
REDIS_POOL_MIN_SIZE=2
REDIS_POOL_MAX_SIZE=10

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# SMS provider: "aliyun" or "tencent"
SMS_PROVIDER=aliyun
SMS_CODE_TTL=300

# Aliyun SMS (dummy values for local)
ALIYUN_ACCESS_KEY_ID=your-key-id
ALIYUN_ACCESS_KEY_SECRET=your-key-secret
ALIYUN_SMS_SIGN_NAME=OpenShop
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# Tencent Cloud SMS (leave blank if using Aliyun)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
