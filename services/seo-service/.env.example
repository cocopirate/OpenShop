SERVICE_NAME=seo-service
SERVICE_PORT=8020
DEBUG=true
APP_ENV=development

# Database
DATABASE_URL=postgresql+asyncpg://openshop:openshop123@localhost:5432/seo_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis (ARQ broker)
REDIS_URL=redis://localhost:6379/0

# AI Service
AI_SERVICE_URL=http://ai-service:8001
AI_SERVICE_KEY=seo-service-key-xxx

# Duplicate detection
DUPLICATE_THRESHOLD=0.75
MAX_RETRIES=3
