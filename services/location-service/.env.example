# location-service – Local development environment
# Copy to .env and fill in real values.
# DO NOT commit .env to source control.

SERVICE_NAME=location-service
SERVICE_PORT=8008
DEBUG=true
ENV=development

# PostgreSQL (local docker-compose)
DATABASE_URL=postgresql+asyncpg://openshop:openshop123@localhost:5432/openshop
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis (local docker-compose)
REDIS_URL=redis://:redis123@localhost:6379/0
REDIS_POOL_MAX_SIZE=10

# RabbitMQ
RABBITMQ_URL=amqp://openshop:openshop123@localhost:5672/
