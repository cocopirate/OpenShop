SERVICE_NAME=ai-service
SERVICE_PORT=8021
DEBUG=true
APP_ENV=development

# Database (independent instance)
DATABASE_URL=postgresql+asyncpg://openshop:openshop123@localhost:5432/openshop
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0

# AI providers
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Aliyun Dashscope (百炼平台) — 千问系列模型
# 密鑰获取: https://bailian.console.aliyun.com -> 我的API-KEY
DASHSCOPE_API_KEY=sk-...
# 可选模型: qwen-turbo / qwen-plus / qwen-max / qwen-long
QWEN_DEFAULT_MODEL=qwen-plus

# Service-to-service auth keys (one per calling service)
SERVICE_KEY_SEO=seo-service-key-xxx
SERVICE_KEY_CS=cs-service-key-xxx

# Rate limiting defaults (can be overridden per service via env)
RATE_LIMIT_RPM=60
RATE_LIMIT_TPM=100000

# Cache
CACHE_DEFAULT_TTL=3600
