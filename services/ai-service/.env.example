SERVICE_NAME=ai-service
SERVICE_PORT=8000
DEBUG=true
APP_ENV=development

# Database (independent instance)
DATABASE_URL=postgresql+asyncpg://openshop:openshop123@localhost:5432/ai_service_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0

# AI providers
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Service-to-service auth keys (one per calling service)
SERVICE_KEY_SEO=seo-service-key-xxx
SERVICE_KEY_CS=cs-service-key-xxx

# Rate limiting defaults (can be overridden per service via env)
RATE_LIMIT_RPM=60
RATE_LIMIT_TPM=100000

# Cache
CACHE_DEFAULT_TTL=3600
