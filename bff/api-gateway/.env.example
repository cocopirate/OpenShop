SERVICE_NAME=api-gateway
SERVICE_PORT=8080
DEBUG=true
ENV=development
REDIS_URL=redis://:redis123@localhost:6379/0
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
USER_SERVICE_URL=http://localhost:8001
MERCHANT_SERVICE_URL=http://localhost:8002
PRODUCT_SERVICE_URL=http://localhost:8003
INVENTORY_SERVICE_URL=http://localhost:8004
ORDER_SERVICE_URL=http://localhost:8005
AFTERSALE_SERVICE_URL=http://localhost:8006
PROMOTION_SERVICE_URL=http://localhost:8007
LOCATION_SERVICE_URL=http://localhost:8008
NOTIFICATION_SERVICE_URL=http://localhost:8009
SMS_SERVICE_URL=http://localhost:8010

# ---------------------------------------------------------------------------
# Crypto / security settings (all optional – leave empty to disable)
# ---------------------------------------------------------------------------

# RSA private key in PEM format (single-line, use \n for newlines).
# Generate: openssl genrsa -out private.pem 2048
# Then paste the contents here, replacing real newlines with \n.
CRYPTO_RSA_PRIVATE_KEY=

# Shared HMAC-SHA256 secret for request signature verification.
CRYPTO_HMAC_SECRET=change-this-hmac-secret-in-production

# JSON list of path prefixes that require X-Timestamp + X-Sign headers.
# Example: '["/api/v1/orders", "/api/v1/payments"]'
CRYPTO_SIGN_PATHS_JSON=[]

# JSON list of path prefixes whose request bodies are hybrid-encrypted
# (AES-256-CBC body + RSA-OAEP encrypted AES session key).
# Example: '["/api/v1/orders"]'
CRYPTO_ENCRYPT_REQUEST_PATHS_JSON=[]

# JSON list of path prefixes whose responses should be AES-encrypted.
# These paths MUST also appear in CRYPTO_ENCRYPT_REQUEST_PATHS_JSON.
# Example: '["/api/v1/orders"]'
CRYPTO_ENCRYPT_RESPONSE_PATHS_JSON=[]
